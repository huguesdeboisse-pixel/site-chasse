---
import Base from '../layouts/Base.astro';
import dataset from '../data/departements-ara.json';
const deps = dataset.departements;
---
<Base title="Tout pour la chasse — Auvergne-Rhône-Alpes">
  <section class="hero">
    <div class="wrap">
      <p class="eyebrow">Pilote · Auvergne-Rhône-Alpes</p>
      <h1>Tout pour la chasse</h1>
      <p class="lede">Toute l'actualité administrative de la chasse dans votre département.</p>
    </div>
  </section>

  <div class="wrap">
    <div class="toolbar">
      <input id="dep-search" class="search" type="search" placeholder="Rechercher un département (nom ou numéro)…" aria-label="Rechercher un département" autocomplete="off" />
    </div>

    <ul class="dep-grid" id="dep-grid">
      {deps.map((d) => (
        <li class="dep-card" data-name={d.nom.toLowerCase()} data-code={d.code}>
          <a href={`/departements/${d.code}/`}>
            <span class="dep-code">{d.code}</span>
            <span class="dep-name">{d.nom}</span>
            <span class="dep-go" aria-hidden="true">&rarr;</span>
          </a>
        </li>
      ))}
    </ul>
    <p class="no-results" id="no-results" hidden>Aucun département ne correspond à votre recherche.</p>
  </div>

  <script is:inline>
    const input = document.getElementById('dep-search');
    const cards = Array.from(document.querySelectorAll('.dep-card'));
    const noRes = document.getElementById('no-results');
    input && input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((c) => {
        const match = c.dataset.name.includes(q) || c.dataset.code.includes(q);
        c.hidden = !match;
        if (match) visible++;
      });
      noRes.hidden = visible > 0;
    });
  </script>
</Base>
