---
import Base from '../layouts/Base.astro';
import dataset from '../data/especes.json';
import { SLUGS } from '../lib/especes';

const icons = import.meta.glob('../icons/especes/*.svg', { eager: true, query: '?raw', import: 'default' }) as Record<string, string>;

function iconFor(nom: string) {
  const slug = SLUGS[nom];
  if (!slug) return null;
  return icons[`../icons/especes/${slug}.svg`] ?? null;
}
---
<Base title="Espèces chassables — Auvergne-Rhône-Alpes" description="Référentiel des espèces chassables : grand gibier, petit gibier sédentaire, gibier d'eau, oiseaux de passage et galliformes de montagne.">
  <div class="wrap prose">
    <h1>Espèces chassables</h1>
    <p>Référentiel national des espèces, indépendant des dates et quotas par département (à venir dans le pipeline de données). {dataset.note}</p>
  </div>

  <div class="wrap">
    <ul class="especes-grid">
      {dataset.especes.map((e) => {
        const svg = iconFor(e.nom);
        return (
          <li class="espece-card">
            <div class="espece-icon" set:html={svg ?? '<span aria-hidden="true">—</span>'} />
            <p class="espece-nom">{e.nom}</p>
            <p class="espece-cat">{e.categorie}</p>
          </li>
        );
      })}
    </ul>
  </div>
</Base>
