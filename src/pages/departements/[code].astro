---
import Base from '../../layouts/Base.astro';
import dataset from '../../data/departements-ara.json';

export function getStaticPaths() {
  return dataset.departements.map((d) => ({ params: { code: d.code }, props: { dep: d } }));
}

interface ArretePeriode {
  objet: string;
  reference: string;
  url_pdf: string;
  statut: string;
}

interface Periodes {
  departement: string;
  saison: string;
  licence_source: string;
  ouverture_generale: {
    date: string;
    source_url: string;
    source_label: string;
    confiance: string;
  };
  arretes_officiels: ArretePeriode[];
}

const { dep } = Astro.props;
const periodesModules = import.meta.glob<{ default: Periodes }>('../../data/periodes/*.json', { eager: true });
const mod = periodesModules[`../../data/periodes/${dep.code}.json`];
const periodes = mod ? mod.default : null;

const MOIS = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
function formatDate(iso: string){
  if(!iso) return '';
  const [y,m,d] = iso.split('-').map(Number);
  return `${d} ${MOIS[m-1]} ${y}`;
}

interface Note { label: string; href: string; }
const notes: Note[] = [
  { label: `Préfecture — ${dep.nom}`, href: dep.prefecture_url },
  { label: dep.fdc_nom, href: dep.fdc_url },
];
let ouvertureRef = 0, arretesRef = 0;
if (periodes) {
  notes.push({ label: periodes.ouverture_generale.source_label, href: periodes.ouverture_generale.source_url });
  ouvertureRef = notes.length;
  notes.push({
    label: `Ensemble des arrêtés préfectoraux ${periodes.saison} (${periodes.arretes_officiels.length} arrêtés) — ${dep.nom}`,
    href: dep.prefecture_url,
  });
  arretesRef = notes.length;
}
---
<Base title={`Chasse en ${dep.nom} (${dep.code})`} description={`Dates d'ouverture et de fermeture, quotas et arrêtés de la chasse en ${dep.nom}.`}>
  <div class="wrap fiche">
    <nav class="breadcrumb"><a href="/">Accueil</a><span>/</span><a href="/">Départements</a><span>/</span>{dep.nom}</nav>

    <header class="fiche-head">
      <span class="dep-badge">{dep.code}</span>
      <div>
        <h1>{dep.nom}</h1>
        <p class="fiche-sources">
          {periodes ? `Saison ${periodes.saison}` : 'Sources officielles'}
          <sup><a class="footnote-ref" href="#s1">1</a></sup>
          <sup><a class="footnote-ref" href="#s2">2</a></sup>
        </p>
      </div>
    </header>

    {periodes ? (
      <>
        <div class="stat-grid">
          <div class="stat-card accent">
            <p class="stat-label">Ouverture générale</p>
            <p class="stat-value">{formatDate(periodes.ouverture_generale.date)}<sup><a class="footnote-ref" href={`#s${ouvertureRef}`}>{ouvertureRef}</a></sup></p>
          </div>
          <div class="stat-card">
            <p class="stat-label">Arrêtés en vigueur</p>
            <p class="stat-value">{periodes.arretes_officiels.length}<sup><a class="footnote-ref" href={`#s${arretesRef}`}>{arretesRef}</a></sup></p>
          </div>
          <div class="stat-card">
            <p class="stat-label">Confiance de la donnée</p>
            <p class="stat-value ok">{periodes.ouverture_generale.confiance}<sup><a class="footnote-ref" href={`#s${ouvertureRef}`}>{ouvertureRef}</a></sup></p>
          </div>
        </div>
      </>
    ) : (
      <div class="empty">
        <p><strong>Données en cours de collecte</strong> pour ce département.</p>
        <p>En attendant, consultez les sources officielles ci-dessous, qui font foi.</p>
      </div>
    )}

    <section class="sources" id="sources">
      <p>Sources</p>
      <ol>
        {notes.map((n, i) => (
          <li id={`s${i + 1}`}>{n.label} — <a href={n.href} target="_blank" rel="noopener noreferrer">consulter ↗</a></li>
        ))}
      </ol>
    </section>
  </div>
</Base>
