---
import Base from '../../layouts/Base.astro';
import dataset from '../../data/departements-france.json';
import especesDataset from '../../data/especes.json';
import { SLUGS } from '../../lib/especes';
import { LOCALISATION } from '../../lib/localisation';
import { OISEAUX_DE_PASSAGE, SOURCE_PASSAGE, dernierSamediAout } from '../../lib/migrateurs';
import { GIBIER_EAU, DEPARTEMENTS_COTIERS, SOURCE_GIBIER_EAU, premierSamediAout } from '../../lib/gibier-eau';

export function getStaticPaths() {
  return dataset.departements.map((d) => ({ params: { code: d.code }, props: { dep: d } }));
}

const DROM_REGIONS = new Set(['Guadeloupe', 'Martinique', 'Guyane', 'La Réunion', 'Mayotte']);

interface Fait {
  label: string;
  detail: string;
  saison?: string;
  source_url: string;
  source_label: string;
}

interface EspecePeriode {
  slug: string;
  faits: Fait[];
}

interface Periodes {
  departement: string;
  saison: string;
  licence_source: string;
  ouverture_generale: {
    date: string;
    fermeture?: string;
    source_url: string;
    source_label: string;
    confiance: string;
  };
  arretes_officiels: { objet: string; reference: string; url_pdf: string; statut: string }[];
  especes?: EspecePeriode[];
}

const { dep } = Astro.props;
const periodesModules = import.meta.glob<{ default: Periodes }>('../../data/periodes/*.json', { eager: true });
const mod = periodesModules[`../../data/periodes/${dep.code}.json`];
const periodes = mod ? mod.default : null;

const icons = import.meta.glob('../../icons/especes/*.svg', { eager: true, query: '?raw', import: 'default' }) as Record<string, string>;

const MOIS = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
function formatDate(iso: string){
  if(!iso) return '';
  const [y,m,d] = iso.split('-').map(Number);
  return `${d === 1 ? '1er' : d} ${MOIS[m-1]} ${y}`;
}

interface Note { label: string; href: string; }
const notes: Note[] = [];
const noteIndex = new Map<string, number>();
function noteRef(label: string, href: string): number {
  const existing = noteIndex.get(href);
  if (existing) return existing;
  notes.push({ label, href });
  const idx = notes.length;
  noteIndex.set(href, idx);
  return idx;
}

// La préfecture n'est citée comme source que lorsqu'un arrêté a réellement été trouvé et confirmé pour ce
// département : sinon, un simple lien vers la page d'accueil de la préfecture ne "source" rien de concret.
let prefRef = 0;
if (periodes) {
  prefRef = noteRef(`Préfecture — ${dep.nom}`, dep.prefecture_url);
}
if (dep.fdc_nom && dep.fdc_url) {
  noteRef(dep.fdc_nom, dep.fdc_url);
}
let ouvertureRef = 0;
if (periodes) {
  ouvertureRef = noteRef(periodes.ouverture_generale.source_label, periodes.ouverture_generale.source_url);
}

const especeParDepartement = new Map((periodes?.especes ?? []).map((e) => [e.slug, e]));

interface EspeceBannerView { nom: string; slug: string | undefined; svg: string | null; }
interface EspeceRow { slug: string; titre: string; valeur: string; refs: number[]; }

const especeViews: EspeceBannerView[] = [];
const especeRows: EspeceRow[] = [];

// Espèces de montagne : elles n'apparaissent que dans les départements où l'arrêté les réglemente
// réellement (présence de données collectées). Chaque affichage est ainsi tracé à une source
// vérifiable, plutôt qu'à une liste géographique à valider à la main. Les manques se comblent au
// fur et à mesure de la collecte des arrêtés.
const ESPECES_MONTAGNE = new Set(['chamois', 'mouflon-mediterraneen', 'tetras-lyre', 'lagopede-alpin', 'perdrix-bartavelle']);

const especesDuTerritoire = especesDataset.especes.filter((e) =>
  'territoire' in e ? e.territoire === dep.region : !DROM_REGIONS.has(dep.region)
);

for (const e of especesDuTerritoire) {
  const slug = SLUGS[e.nom];
  // Masque une espèce de montagne là où le département n'a pas d'arrêté la réglementant.
  if (slug && ESPECES_MONTAGNE.has(slug) && !especeParDepartement.get(slug)?.faits?.length) continue;
  const svg = slug ? icons[`../../icons/especes/${slug}.svg`] ?? null : null;
  especeViews.push({ nom: e.nom, slug, svg });
  if (!slug) continue;

  const data = especeParDepartement.get(slug);
  const faits = data?.faits ?? [];
  const passage = OISEAUX_DE_PASSAGE[slug];
  const ge = GIBIER_EAU[slug];
  // Le département a-t-il déjà collecté les VRAIES dates de cette espèce ? On l'estime en cherchant,
  // dans le détail d'un fait, un mois ou une date au format jj/mm ACCOMPAGNÉ d'une année de la saison
  // en cours (2026/2027). Cela évite de confondre les vraies dates avec un simple renvoi à un arrêté
  // (« arrêtés ministériels du 24 mars 2006 et du 19 janvier 2009 » contient des mois mais pas la saison).
  // Si les dates sont déjà là, on n'ajoute pas la ligne « dates nationales » (doublon/conflit).
  const anneesSaison = periodes ? periodes.saison.split('-') : [];
  // Un fait « donne les vraies dates » s'il contient au moins DEUX repères de date (mois ou jj/mm),
  // signe d'une plage « du … au … », ET une année de la saison en cours. Cela évite de confondre avec
  // une date isolée (retour de carnet, seuil de PMA) ou un renvoi d'arrêté (« 24 mars 2006 »…).
  // Un repère de date = un jour suivi d'un mois (« 31 mars », « 1er août ») OU un format jj/mm.
  // On exige le jour pour ne pas attraper un mois caché dans un mot (« mai » dans « do-mai-ne »).
  const RE_DATE = /\d{1,2}\s?(?:er)?\s?(?:janvier|février|fevrier|mars|avril|mai|juin|juillet|août|aout|septembre|octobre|novembre|décembre|decembre)|\d{1,2}[\/.]\d{1,2}/gi;
  const donneVraiesDates = (detail: string) => (detail.match(RE_DATE)?.length ?? 0) >= 2 && anneesSaison.some((an) => detail.includes(an));
  const aDejaDate = faits.some((f) => donneVraiesDates(f.detail));

  // 1. Oiseau de passage : ligne « dates nationales » (arrêté du 24 mars 2006 / 19 janvier 2009),
  //    ajoutée seulement si aucune date n'a déjà été collectée pour ce département.
  if (passage && periodes) {
    if (passage.statut === 'moratoire') {
      const ref = noteRef(SOURCE_PASSAGE.label, SOURCE_PASSAGE.url);
      especeRows.push({ slug, titre: `${e.nom} — Statut`, valeur: "Chasse suspendue (moratoire national) : aucune date d'ouverture pour cette saison.", refs: [ref] });
    } else if (!aDejaDate) {
      const anneeOuverture = Number(periodes.saison.split('-')[0]);
      const anneeFermeture = Number(periodes.saison.split('-')[1]);
      const ouvertureIso = passage.ouverture === 'dernier-samedi-aout'
        ? dernierSamediAout(anneeOuverture)
        : periodes.ouverture_generale.date;
      // Fermeture : date nationale par défaut, ou dérogation si le département est listé.
      const derog = passage.fermetureDerogation && passage.fermetureDerogation.departements.includes(dep.code)
        ? passage.fermetureDerogation
        : null;
      const ferm = derog ?? passage.fermeture;
      const fermetureIso = `${anneeFermeture}-${String(ferm.mois).padStart(2, '0')}-${String(ferm.jour).padStart(2, '0')}`;
      const mentionOuverture = passage.ouverture === 'dernier-samedi-aout'
        ? `Ouverture le ${formatDate(ouvertureIso)} (dernier samedi d'août)`
        : `Ouverture générale du département (${formatDate(ouvertureIso)})`;
      const mentions: string[] = [];
      if (derog?.note) mentions.push(derog.note);
      if (passage.note) mentions.push(passage.note);
      const valeur = `${mentionOuverture} — fermeture le ${formatDate(fermetureIso)}.${mentions.length ? ' ' + mentions.join(' ') : ''}`;
      // Référence : l'arrêté départemental pour l'ouverture générale, l'arrêté national pour la fermeture.
      const refs: number[] = [];
      if (passage.ouverture === 'generale' && ouvertureRef) refs.push(ouvertureRef);
      refs.push(noteRef(SOURCE_PASSAGE.label, SOURCE_PASSAGE.url));
      especeRows.push({ slug, titre: e.nom, valeur, refs });
    }
  }

  // 1 bis. Gibier d'eau : statut particulier (moratoire / mer uniquement), ou ouverture nationale
  //        échelonnée (domaine public maritime / plans d'eau intérieurs) + fermeture nationale.
  if (ge && periodes) {
    if (ge.statut === 'moratoire') {
      const ref = noteRef(SOURCE_GIBIER_EAU.label, SOURCE_GIBIER_EAU.url);
      especeRows.push({ slug, titre: `${e.nom} — Statut`, valeur: "Chasse suspendue (moratoire national) : aucune date d'ouverture pour cette saison.", refs: [ref] });
    } else if (ge.statut === 'mer-uniquement') {
      const ref = noteRef(SOURCE_GIBIER_EAU.label, SOURCE_GIBIER_EAU.url);
      especeRows.push({ slug, titre: `${e.nom} — Statut`, valeur: "Chasse à terre suspendue ; autorisée uniquement en mer, jusqu'à la limite des eaux territoriales.", refs: [ref] });
    } else if (!aDejaDate) {
      const anneeOuverture = Number(periodes.saison.split('-')[0]);
      const anneeFermeture = Number(periodes.saison.split('-')[1]);
      const interieurIso = ge.ouvertureInterieur === '15-septembre'
        ? `${anneeOuverture}-09-15`
        : `${anneeOuverture}-08-21`;
      const paliers: string[] = [];
      if (DEPARTEMENTS_COTIERS.includes(dep.code)) {
        paliers.push(`sur le domaine public maritime dès le ${formatDate(premierSamediAout(anneeOuverture))}`);
      }
      paliers.push(`sur les marais, étangs et plans d'eau dès le ${formatDate(interieurIso)}`);
      const fermetureIso = `${anneeFermeture}-${String(ge.fermeture.mois).padStart(2, '0')}-${String(ge.fermeture.jour).padStart(2, '0')}`;
      const noteCote = DEPARTEMENTS_COTIERS.includes(dep.code)
        ? " Sur le domaine public maritime, la fermeture est repoussée (10 février pour certaines espèces)."
        : '';
      const valeur = `Ouverture échelonnée : ${paliers.join(' ; ')} — fermeture le ${formatDate(fermetureIso)}.${noteCote}${ge.note ? ' ' + ge.note : ''}`;
      const ref = noteRef(SOURCE_GIBIER_EAU.label, SOURCE_GIBIER_EAU.url);
      especeRows.push({ slug, titre: e.nom, valeur, refs: [ref] });
    }
  }

  // 2. Faits collectés dans l'arrêté départemental (dates locales détaillées, quotas/PMA, statut ESOD…).
  //    On les affiche TOUJOURS : mieux vaut un léger doublon sur un renvoi que de risquer de masquer
  //    une information réelle (ex. interdiction locale, chasse de nuit).
  for (const fait of faits) {
    const ref = noteRef(fait.source_label, fait.source_url);
    const saisonNote = fait.saison && fait.saison !== periodes?.saison
      ? ` (saison ${fait.saison}, dernière valeur connue)`
      : '';
    const titreFait = fait.label === 'Dates de chasse' ? e.nom : `${e.nom} — ${fait.label}`;
    especeRows.push({ slug, titre: titreFait, valeur: `${fait.detail}${saisonNote}`, refs: [ref] });
  }

  // 3. Ni ligne nationale calculable, ni fait collecté → message honnête.
  if (!faits.length && !(passage && periodes) && !(ge && periodes)) {
    const ref = ouvertureRef || prefRef;
    especeRows.push({ slug, titre: `${e.nom} — Statut`, valeur: "Aucune règle spécifique recensée pour cette espèce dans l'arrêté de ce département.", refs: ref ? [ref] : [] });
  }
}
---
<Base title={`Chasse ${LOCALISATION[dep.code]} (${dep.code})`} description={`Dates d'ouverture et de fermeture, quotas et arrêtés de la chasse ${LOCALISATION[dep.code]}.`}>
  <div class="wrap">
    <div class="especes-banner" role="group" aria-label="Filtrer par espèce">
      {especeViews.map((e) => (
        <button type="button" class="espece-btn" data-slug={e.slug} aria-pressed="false">
          <span class="espece-btn-icon" set:html={e.svg ?? '<span aria-hidden="true">—</span>'} />
          <span class="espece-btn-nom">{e.nom}</span>
        </button>
      ))}
    </div>
  </div>

  <div class="wrap fiche">
    <nav class="breadcrumb"><a href="/">Accueil</a><span>/</span><a href="/">Départements</a><span>/</span>{dep.nom}</nav>

    <header class="fiche-head">
      <div class="fiche-head-row">
        <span class="dep-badge">{dep.code}</span>
        <h1>{dep.nom}</h1>
      </div>
      {periodes && (
        <p class="fiche-sources">
          Saison {periodes.saison}
        </p>
      )}
    </header>

    <div class="cartouche">
      {periodes ? (
        <div class="info-row" id="row-generale">
          <p class="info-title">Ouverture générale</p>
          <p class="info-value">
            {formatDate(periodes.ouverture_generale.date)}
            {periodes.ouverture_generale.fermeture && <> — {formatDate(periodes.ouverture_generale.fermeture)}</>}
            <sup><a class="footnote-ref" href={`#s${ouvertureRef}`}>{ouvertureRef}</a></sup>
          </p>
        </div>
      ) : (
        <div class="info-row" id="row-generale">
          <p class="info-title">Données en cours de collecte</p>
          <p class="info-value">Aucun arrêté signé confirmé pour cette campagne à ce jour.</p>
        </div>
      )}

      {especeRows.map((r) => (
        <div class="info-row espece-row" data-slug={r.slug} hidden>
          <p class="info-title">{r.titre}</p>
          <p class="info-value">{r.valeur}{r.refs.map((ref) => <sup><a class="footnote-ref" href={`#s${ref}`}>{ref}</a></sup>)}</p>
        </div>
      ))}
    </div>

    {/* Espace publicitaire retiré pour le moment — à réactiver plus tard (voir aussi .ad-slot dans Base.astro).
    <div class="ad-slot" role="complementary" aria-label="Emplacement publicitaire">
      <span class="ad-slot-label">Publicité</span>
      <span class="ad-slot-body">Emplacement disponible</span>
    </div>
    */}

    {notes.length > 0 && (
      <section class="sources" id="sources">
        <p>Sources</p>
        <ol>
          {notes.map((n, i) => (
            <li id={`s${i + 1}`}>{n.label} — <a href={n.href} target="_blank" rel="noopener noreferrer">consulter ↗</a></li>
          ))}
        </ol>
      </section>
    )}
  </div>

  <script>
    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.espece-btn'));
    const generale = document.getElementById('row-generale')!;
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.espece-row'));
    const selected = new Set<string>();

    function render() {
      buttons.forEach((b) => {
        const on = selected.has(b.dataset.slug!);
        b.setAttribute('aria-pressed', on ? 'true' : 'false');
        b.classList.toggle('active', on);
      });
      rows.forEach((r) => { r.hidden = !selected.has(r.dataset.slug!); });

      const visible = [generale, ...rows].filter((r) => !r.hidden);
      [generale, ...rows].forEach((r) => r.classList.remove('is-last'));
      visible[visible.length - 1]?.classList.add('is-last');
    }

    buttons.forEach((b) => b.addEventListener('click', () => {
      const slug = b.dataset.slug!;
      if (selected.has(slug)) selected.delete(slug); else selected.add(slug);
      render();
    }));

    render();
  </script>

  <script define:vars={{ depCode: dep.code }} is:inline>
    window.trackEvent && window.trackEvent('department_view', { code: depCode });
    document.querySelectorAll('.espece-btn').forEach(function (b) {
      b.addEventListener('click', function () {
        window.trackEvent && window.trackEvent('species_select', {
          code: depCode,
          slug: b.dataset.slug,
          selected: b.getAttribute('aria-pressed') === 'true',
        });
      });
    });
  </script>
</Base>
