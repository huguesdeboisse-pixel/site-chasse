---
import Base from '../../layouts/Base.astro';
import SourceLink from '../../components/SourceLink.astro';
import dataset from '../../data/departements-ara.json';

export function getStaticPaths() {
  return dataset.departements.map((d) => ({ params: { code: d.code }, props: { dep: d } }));
}

const { dep } = Astro.props;
const periodesModules = import.meta.glob('../../data/periodes/*.json', { eager: true });
const mod = periodesModules[`../../data/periodes/${dep.code}.json`];
const periodes = mod ? (mod.default ?? mod) : null;

const MOIS = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
function formatDate(iso){
  if(!iso) return '';
  const [y,m,d] = iso.split('-').map(Number);
  return `${d} ${MOIS[m-1]} ${y}`;
}
function statutClass(s){
  return (s === 'signé' || s === 'en vigueur') ? 'chip-ok' : 'chip-muted';
}
---
<Base title={`Chasse en ${dep.nom} (${dep.code})`} description={`Dates d'ouverture et de fermeture, quotas et arrêtés de la chasse en ${dep.nom}.`}>
  <div class="wrap fiche">
    <nav class="breadcrumb"><a href="/">Accueil</a><span>/</span><a href="/">Départements</a><span>/</span>{dep.nom}</nav>

    <header class="fiche-head">
      <span class="dep-badge">{dep.code}</span>
      <div>
        <h1>{dep.nom}</h1>
        <p class="fiche-sources">
          Sources officielles :
          <span>Fédération des chasseurs</span><SourceLink href={dep.fdc_url} label={`Site officiel : ${dep.fdc_nom}`} />
          <span class="dot">·</span>
          <span>Préfecture</span><SourceLink href={dep.prefecture_url} label="Site de la préfecture (arrêtés)" />
        </p>
      </div>
    </header>

    {periodes ? (
      <>
        <section class="card ouverture">
          <p class="card-label">Ouverture générale · saison {periodes.saison}</p>
          <p class="big-date">{formatDate(periodes.ouverture_generale.date)}<SourceLink href={periodes.ouverture_generale.source_url} label={periodes.ouverture_generale.source_label} /></p>
        </section>

        <section>
          <h2>Arrêtés en vigueur</h2>
          <ul class="arretes">
            {periodes.arretes_officiels.map((a) => (
              <li class="arrete">
                <span class="arrete-main">
                  <span class="arrete-objet">{a.objet}</span>
                  <span class="arrete-ref">{a.reference}</span>
                </span>
                <span class={`chip ${statutClass(a.statut)}`}>{a.statut}</span>
                <SourceLink href={a.url_pdf} label={`Ouvrir le PDF officiel — ${a.objet}`} />
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : (
      <div class="empty">
        <p><strong>Données en cours de collecte</strong> pour ce département.</p>
        <p>En attendant, consultez les sources officielles ci-dessus, qui font foi.</p>
      </div>
    )}
  </div>
</Base>
