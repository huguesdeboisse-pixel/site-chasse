---
interface Props { title?: string; description?: string; }
const {
  title = "Chasse — données de référence",
  description = "Données administratives de la chasse en France, agrégées et sourcées."
} = Astro.props;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root { --vert:#2f7d4f; --txt:#1f2937; --muted:#6b7280; --bord:#e5e7eb; }
      * { box-sizing:border-box; }
      body { margin:0; font-family:system-ui,-apple-system,"Segoe UI",Roboto,sans-serif; color:var(--txt); line-height:1.55; }
      header, main, footer { max-width:900px; margin:0 auto; padding:1rem 1.25rem; }
      header { display:flex; gap:1.25rem; align-items:baseline; border-bottom:1px solid var(--bord); }
      header .brand { font-weight:700; color:var(--vert); text-decoration:none; }
      nav a { margin-right:1rem; color:var(--muted); font-size:.95rem; text-decoration:none; }
      h1 { font-size:1.6rem; }
      a { color:var(--vert); }
      .grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:.75rem; padding:0; list-style:none; }
      .card { border:1px solid var(--bord); border-radius:10px; padding:.85rem 1rem; }
      .card a { text-decoration:none; font-weight:600; }
      .src { font-size:.85rem; color:var(--muted); }
      .warn { background:#fff7ed; border:1px solid #fed7aa; border-radius:8px; padding:.6rem .8rem; font-size:.9rem; }
      footer { border-top:1px solid var(--bord); color:var(--muted); font-size:.85rem; margin-top:2rem; }
      table { border-collapse:collapse; width:100%; }
      td, th { border:1px solid var(--bord); padding:.4rem .6rem; text-align:left; font-size:.92rem; }
    </style>
  </head>
  <body>
    <header>
      <a class="brand" href="/">Chasse · référence</a>
      <nav>
        <a href="/">Départements</a>
        <a href="/methodologie/">Méthodologie &amp; sources</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>Données indicatives, agrégées depuis des sources officielles.
      <strong>Vérifiez toujours l'arrêté préfectoral en vigueur</strong> avant de chasser.
      Contenu des préfectures réutilisé sous licence ouverte Etalab 2.0.</p>
    </footer>
  </body>
</html>
